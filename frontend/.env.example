# =============================================================================
# 前端环境变量配置模板
# =============================================================================
# 使用说明：
# 1. 复制此文件为 .env.local (同目录下)
# 2. 替换所有占位符为实际值
# 3. .env.local 已被 .gitignore 排除，不会提交到 Git
# =============================================================================

# =============================================================================
# API端点配置
# =============================================================================
# 后端API地址（需与后端API_PORT保持一致）
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# 前端开发服务器端口（Next.js默认3000）
# 可通过 PORT=3001 npm run dev 启动在其他端口
PORT=3000

# =============================================================================
# 营销页面媒体资源
# =============================================================================
# 主页背景视频（建议使用CDN链接，避免将大文件提交到Git）
NEXT_PUBLIC_HERO_VIDEO_URL=https://your-cdn.example.com/video/hero.mp4

# 主页封面图（可选）
# NEXT_PUBLIC_HERO_POSTER_URL=https://your-cdn.example.com/images/hero-poster.jpg

# =============================================================================
# 功能开关（可选）
# =============================================================================
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_FEEDBACK=true

# =============================================================================
# 第三方服务（可选）
# =============================================================================
# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# 注意事项
# =============================================================================
# 1. 所有 NEXT_PUBLIC_ 前缀的变量会暴露给浏览器，不要包含敏感信息
# 2. 后端环境变量请配置在根目录的 .env 文件中
# 3. 生产环境部署时，在部署平台单独配置这些变量
