        <mxCell id="4" value="剧本创作智能体&#xa;script_writer.py + episode_script_planner.py&#xa;• 场景拆分与镜头脚本&#xa;• story_plan / mode_router 输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B1D32;fontColor=#FFFFFF;strokeColor=#4FFFB0;strokeWidth=2;" vertex="1" parent="1">
