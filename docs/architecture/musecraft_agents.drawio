        </mxCell>
        <mxCell id="3" value="概念规划智能体&#xa;concept_planner.py&#xa;• 视觉/叙事蓝图&#xa;• 引用 style_taxonomy.yaml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B1D32;fontColor=#FFFFFF;strokeColor=#4FFFB0;strokeWidth=2;" vertex="1" parent="1">
