        <mxCell id="6" value="视频生成智能体&#xa;video_generator.py + video_generation_tool_v2.py&#xa;• 场景级视频生成&#xa;• motion/script prompts 输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0B243A;fontColor=#FFFFFF;strokeColor=#4FFFB0;strokeWidth=2;" vertex="1" parent="1">
