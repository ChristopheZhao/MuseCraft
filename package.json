{
  "name": "short-video-maker",
  "version": "1.0.0",
  "description": "AI-powered short video generation platform",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --no-cache",
    "type-check": "tsc --noEmit --incremental false",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:e2e": "npm run test:smoke",
    "test:e2e:legacy": "jest --testPathPattern=__tests__/e2e",
    "test:smoke": "node scripts/frontend-smoke.js",
    "test:performance": "jest --testPathPattern=__tests__/performance",
    "test:a11y": "jest --testPathPattern=__tests__/accessibility",
    "test:all": "npm run test:integration && npm run test:e2e && npm run test:performance && npm run test:a11y"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.300.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.0",
    "react-player": "^2.13.0",
    "tailwind-merge": "^2.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.8.2",
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.0",
    "@types/puppeteer": "^7.0.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.51.0",
    "eslint-config-next": "^14.0.0",
    "intersection-observer": "^0.12.2",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-websocket-mock": "^2.5.0",
    "lighthouse": "^11.3.0",
    "postcss": "^8.4.0",
    "puppeteer": "^21.5.2",
    "resize-observer-polyfill": "^1.5.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.0",
    "web-vitals": "^3.5.0",
    "whatwg-fetch": "^3.6.19"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
