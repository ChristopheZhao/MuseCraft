{
  "name": "short-video-maker",
  "version": "1.0.0",
  "description": "AI-powered short video generation platform",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx --no-cache",
    "type-check": "tsc --noEmit --incremental false",
    "test": "npm run test:ci",
    "test:ci": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --selectProjects unit --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --selectProjects integration --runInBand __tests__/integration/runtime-gate-sync.test.tsx __tests__/integration/project-mode-store-smoke.test.tsx __tests__/integration/realtime-communication.test.tsx __tests__/integration/app-store-result-finalization.test.ts __tests__/integration/task-polling-runtime-authority.test.tsx",
    "test:e2e": "npm run test:smoke",
    "test:e2e:legacy": "jest --testPathPattern=__tests__/e2e",
    "test:smoke": "node scripts/frontend-smoke.js",
    "test:performance": "jest --selectProjects performance --runInBand",
    "test:a11y": "jest --selectProjects accessibility --runInBand",
    "test:legacy:integration": "jest --selectProjects integration --runInBand",
    "test:all": "npm run test:ci"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.300.0",
    "next": "15.5.20",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.0",
    "react-player": "^2.13.0",
    "tailwind-merge": "^2.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.8.2",
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.8.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "autoprefixer": "^10.4.0",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.20",
    "intersection-observer": "^0.12.2",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-websocket-mock": "^2.5.0",
    "postcss": "8.5.10",
    "puppeteer": "24.43.1",
    "resize-observer-polyfill": "^1.5.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.0",
    "web-vitals": "^3.5.0",
    "whatwg-fetch": "^3.6.19"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
