# =============================================================================
# 短视频制作平台 - 后端环境配置模板
# =============================================================================
# 使用说明：
# 1. 复制此文件为 ../.env (项目根目录)
# 2. 替换所有占位符为实际值
# 3. 不要提交包含敏感信息的.env文件到Git
# =============================================================================

# =============================================================================
# 应用基本配置
# =============================================================================
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
LOG_FORMAT=json
API_V1_STR=/api/v1
PROJECT_NAME=Short Video Maker API

# API服务器配置
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# 日志配置
# =============================================================================
MAS_LOG_DIR=./logs/mas

# =============================================================================
# 数据库配置
# =============================================================================
DATABASE_URL=mysql://user:password@localhost:3306/short_video_maker
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=short_video_maker
DATABASE_USER=user
DATABASE_PASSWORD=password

# =============================================================================
# Redis配置
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# Celery任务队列配置
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# 文件存储配置
# =============================================================================
STORAGE_TYPE=local  # local, s3, oss
UPLOAD_PATH=./storage/uploads
GENERATED_PATH=./storage/generated
TEMP_PATH=./storage/temp
MAX_FILE_SIZE=100

# 阿里云OSS配置 (可选)
# OSS_ENDPOINT=http://oss-cn-shanghai.aliyuncs.com
# OSS_BUCKET_NAME=your-bucket-name
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_IMAGE_DIR=images

# =============================================================================
# AI服务API密钥 - 国际服务
# =============================================================================
# OpenAI配置 (可选)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Stability AI配置 (可选)
# STABILITY_API_KEY=your-stability-api-key-here

# Suno AI配置 (可选)
# SUNO_API_KEY=your-suno-api-key-here

# =============================================================================
# 配音合成配置
# =============================================================================
VOICE_PRIMARY_PROVIDER=aliyun
VOICE_PROVIDER_FALLBACKS=[]
VOICE_DEFAULT_SAMPLE_RATE=16000
VOICE_DEFAULT_FORMAT=wav
VOICE_DEFAULT_VOICE_ID=siqi
VOICE_HTTP_TIMEOUT=30
VOICE_MAX_CHARS_PER_REQUEST=300
VOICE_CATALOG_PATH=./config/voice_manifest.json

# 阿里云智能语音交互（TTS）
# ALIYUN_TTS_APP_KEY=your-app-key
# ALIYUN_TTS_ACCESS_KEY_ID=your-access-key-id
# ALIYUN_TTS_ACCESS_KEY_SECRET=your-access-key-secret
# ALIYUN_TTS_REGION=cn-shanghai

# =============================================================================
# AI服务API密钥 - 中国服务（推荐）
# =============================================================================
# Kimi (月之暗面) - 推荐用于文本生成
# KIMI_API_KEY=sk-your-kimi-api-key-here
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# GLM-4.5 (智谱AI) - 支持文本/图像/视频生成
# GLM_API_KEY=your-glm-api-key-here
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek - 当前 concept_planner 默认 LLM route 的凭据由这里配置，
# route authority 本身在 backend/app/config/llm_policies.yaml
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# Doubao (字节跳动/火山引擎)
# DOUBAO_API_KEY=your-doubao-api-key-here
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com

# =============================================================================
# AI服务配置
# =============================================================================
AI_SERVICE_TIMEOUT=120
AI_SERVICE_MAX_RETRIES=3
AI_CACHE_TTL=3600

# =============================================================================
# Agent 超时配置
# =============================================================================
CONCEPT_PLANNER_TIMEOUT_SECONDS=360

# =============================================================================
# Project 角色库参考图（可选）
# =============================================================================
PROJECT_CHARACTER_REFERENCE_IMAGES_ENABLED=false
PROJECT_CHARACTER_REFERENCE_AVATAR_SIZE=1024x1024
PROJECT_CHARACTER_REFERENCE_FULL_BODY_SIZE=1024x1792

# =============================================================================
# 结构化输出（JSON）稳定性配置（可选）
# =============================================================================
# 结构化输出优先稳定性，降低格式漂移（尤其是回退模型）
LLM_JSON_TEMPERATURE=0.2
LLM_JSON_TEMPERATURE_FALLBACK=0.2

# =============================================================================
# 工作流优化配置
# =============================================================================
WORKFLOW_OPTIMIZATION_LEVEL=balanced  # conservative, balanced, aggressive
WORKFLOW_EXECUTION_STRATEGY=adaptive  # pipeline, react, adaptive
MAX_CONCURRENT_AGENTS=4
ENABLE_WORKFLOW_CACHING=true

# =============================================================================
# ReAct Agent 配置（可选）
# =============================================================================
# 结构化观察契约严格模式：true=严格校验schema（缺字段/错类型将抛错），false=仅告警并跳过
REACT_OBS_SCHEMA_STRICT=true
# 观察压缩触发阈值（Config over Constants）
REACT_OBS_SCENE_THRESHOLD=8
REACT_OBS_SIZE_THRESHOLD=2000
# 事件标签映射（仅用于日志标签；JSON 字符串或留空）
# 例：前缀匹配 → 标签
REACT_ACTION_LABEL_MAP={"video_generation.":"video_generation","image_generation.":"image_generation","voice_synth":"voice_synth","audio_processor":"audio_process"}
# 是否启用首轮 plan-only（通常关闭，采用单段式 ReAct）
REACT_PLAN_ONLY_ENABLED=false
# 是否仅在任务完成时写入WF（默认 false，推荐中途也写入，便于断点续跑）
REACT_WRITE_WF_ON_COMPLETE_ONLY=false

# =============================================================================
# 质量控制配置
# =============================================================================
ENABLE_QUALITY_CONTROL=false
QUALITY_CONTROL_THRESHOLD=5.0
CONTENT_SAFETY_LEVEL=moderate  # strict, moderate, relaxed
ENABLE_HUMAN_REVIEW=false

# =============================================================================
# 监控和分析配置
# =============================================================================
ENABLE_PERFORMANCE_MONITORING=true
METRICS_RETENTION_DAYS=30
ENABLE_COST_TRACKING=true
COST_ALERT_THRESHOLD=10.0

# =============================================================================
# 错误恢复配置
# =============================================================================
ENABLE_ERROR_RECOVERY=true
ERROR_RECOVERY_MAX_ATTEMPTS=3
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# =============================================================================
# 资源管理配置
# =============================================================================
MAX_MEMORY_USAGE_PERCENT=85
MAX_CPU_USAGE_PERCENT=80
MAX_DISK_USAGE_PERCENT=90

# =============================================================================
# WebSocket配置
# =============================================================================
WEBSOCKET_PATH=/ws

# =============================================================================
# 开发和测试配置
# =============================================================================
# TEST_MODE=false
# ENABLE_DEBUG_LOGGING=false
# SKIP_AI_CALLS=false

# =============================================================================
# 注意：前端环境变量请配置在 frontend/.env.local
# =============================================================================
# 前端变量（NEXT_PUBLIC_*）应在 frontend/.env.local 中配置
# 详见 frontend/.env.example
REACT_EPISODIC_LOG_ENABLED=false
REACT_CONTEXT_INCLUDE_RECENT_STEPS=true
REACT_CONTEXT_RECENT_STEPS_K=3
REACT_CONTEXT_INCLUDE_NOTES=false
REACT_CONTEXT_NOTES_LIMIT=5
REACT_CONTEXT_INCLUDE_ARTIFACT_PREVIEW=false
