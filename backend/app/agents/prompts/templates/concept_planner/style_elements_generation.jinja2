    "narrative_style": "纪录片式/电影叙事式/商业推广式等",
    "production_taste": "极简/精致/真实质朴等",
    "emotional_tone": "主要情绪关键字",
    "style_reasoning": "阐述选择理由和预期效果"
  },
  "content_elements": {
    "characters": [
      {
        "canonical_name": "角色唯一标识（英文或中性编号）",
        "display_name": "对外呈现名称（可为中文）",
        "type": "角色类型（人类/灵兽/抽象等）",
        "abstract_traits": ["3-5 个特征，含外形/性格/象征"],
        "visual_identity": ["颜色/材质/配饰等"],
