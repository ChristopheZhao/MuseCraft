        "mood": "氛围描述",
        "key_features": ["突出的视觉元素"]
      }
    ],
    "objects_and_props": [
      {
        "category": "道具类别",
        "items": ["具体物品"],
        "significance": "为何重要"
      }
    ],
    "concepts_and_ideas": [
      {
        "concept": "抽象概念",
        "visualization_approach": "可视化方式"
      }
    ]
  },
  "consistency_hints": {
    "visual": "跨场景需要保持的视觉要点",
    "narrative": "叙事连贯性提醒",
    "color_palette": ["主题色1", "主题色2"],
    "risks": ["潜在冲突或易出错点"]
