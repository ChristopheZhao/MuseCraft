# =============================================================================
# 短视频制作平台 - 环境配置文件示例
# =============================================================================

# =============================================================================
# 应用基本配置
# =============================================================================
DEBUG=false
SECRET_KEY=your-super-secret-key-here-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
LOG_LEVEL=INFO
LOG_FORMAT=json
API_V1_STR=/api/v1
PROJECT_NAME=Short Video Maker API

# =============================================================================
# 数据库配置
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/short_video_maker
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=short_video_maker
DATABASE_USER=user
DATABASE_PASSWORD=password

# =============================================================================
# Redis配置
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# Celery任务队列配置
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# 文件存储配置
# =============================================================================
STORAGE_TYPE=local  # local, s3, oss
UPLOAD_PATH=./storage/uploads
GENERATED_PATH=./storage/generated
TEMP_PATH=./storage/temp
MAX_FILE_SIZE=100  # MB


# AWS S3配置 (可选)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=your_bucket_name

# 阿里云OSS配置 (可选)
# OSS_ACCESS_KEY_ID=your_oss_access_key
# OSS_ACCESS_KEY_SECRET=your_oss_secret_key
# OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
# OSS_BUCKET_NAME=your_bucket_name
# OSS_IMAGE_DIR=images

# =============================================================================
# AI服务API密钥 - 国际服务
# =============================================================================

# OpenAI配置 (推荐)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic配置 (可选)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Stability AI配置 (用于图像生成)
# STABILITY_API_KEY=your-stability-api-key-here

# Runway ML配置 (用于视频生成)
# RUNWAY_API_KEY=your-runway-api-key-here

# Suno AI配置 (用于背景音乐生成)
# SUNO_API_KEY=your-suno-api-key-here

# MidJourney配置 (可选)
# MIDJOURNEY_API_KEY=your-midjourney-api-key-here

# =============================================================================
# AI服务API密钥 - 中国服务
# =============================================================================

# Kimi K2 (月之暗面) - 万亿参数MoE模型，专为智能体设计
# KIMI_API_KEY=your-kimi-api-key-here
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# GLM-4.5 (智谱AI) - 支持文本生成、图像生成(CogView)、视频生成(CogVideoX)
# GLM_API_KEY=your-glm-api-key-here
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Doubao (字节跳动/火山引擎)
# DOUBAO_API_KEY=your-doubao-api-key-here
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com

# 即梦图像生成 (基于Doubao)
# JIMENG_API_KEY=your-jimeng-api-key-here
# JIMENG_BASE_URL=https://api.302.ai/doubao/drawing

# MiniMax视频生成 (abab-video-1)
# MINIMAX_API_KEY=your-minimax-api-key-here
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# 腾讯混元视频
# HUNYUAN_VIDEO_API_KEY=your-hunyuan-api-key-here
# HUNYUAN_VIDEO_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1

# Doubao视频 (Seedance)
# DOUBAO_VIDEO_API_KEY=your-doubao-video-api-key-here
# DOUBAO_VIDEO_BASE_URL=https://ark.cn-beijing.volces.com

# =============================================================================
# AI服务配置
# =============================================================================
AI_SERVICE_TIMEOUT=120
AI_SERVICE_MAX_RETRIES=3
AI_CACHE_TTL=3600

# =============================================================================
# 工作流优化配置
# =============================================================================
WORKFLOW_OPTIMIZATION_LEVEL=balanced  # conservative, balanced, aggressive
WORKFLOW_EXECUTION_STRATEGY=adaptive  # pipeline, react, adaptive
MAX_CONCURRENT_AGENTS=4
ENABLE_WORKFLOW_CACHING=true

# =============================================================================
# 质量控制配置
# =============================================================================
ENABLE_QUALITY_CONTROL=true
QUALITY_CONTROL_THRESHOLD=5.0
CONTENT_SAFETY_LEVEL=moderate  # strict, moderate, relaxed
ENABLE_HUMAN_REVIEW=false

# =============================================================================
# 监控和分析配置
# =============================================================================
ENABLE_PERFORMANCE_MONITORING=true
METRICS_RETENTION_DAYS=30
ENABLE_COST_TRACKING=true
COST_ALERT_THRESHOLD=10.0

# =============================================================================
# 错误恢复配置
# =============================================================================
ENABLE_ERROR_RECOVERY=true
ERROR_RECOVERY_MAX_ATTEMPTS=3
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# =============================================================================
# 资源管理配置
# =============================================================================
MAX_MEMORY_USAGE_PERCENT=85
MAX_CPU_USAGE_PERCENT=80
MAX_DISK_USAGE_PERCENT=90

# =============================================================================
# WebSocket配置
# =============================================================================
WEBSOCKET_PATH=/ws

# =============================================================================
# CORS配置 (开发环境)
# =============================================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# =============================================================================
# 开发和测试配置
# =============================================================================
# TEST_MODE=false
# ENABLE_DEBUG_LOGGING=false
# SKIP_AI_CALLS=false

# =============================================================================
# 前端营销主页媒体可配置（避免将大视频提交到Git）
# =============================================================================
# NEXT_PUBLIC_HERO_VIDEO_URL=https://your-cdn.example.com/marketing/hero.mp4
# NEXT_PUBLIC_HERO_POSTER_URL=https://your-cdn.example.com/marketing/hero-poster.jpg
# 控制台演示视频（生成完成后的播放器/导出默认使用）
# 留空将回退到项目内置的 `/marketing/hero.mp4`
# NEXT_PUBLIC_DEMO_VIDEO_URL=https://your-cdn.example.com/demo/sample.mp4
# 选择视频提供商（与后端服务动态切换）
# 可选：cogvideox-3, doubao, minimax, runway, pika
VIDEO_GENERATION_PROVIDER=cogvideox-3

# 选择图像提供商（可与视频分离切换）
# 可选：zhipu, doubao, openai
IMAGE_GENERATION_PROVIDER=zhipu
DEFAULT_VIDEO_RESOLUTION=1280x720
